rules_version = '2';

// ─────────────────────────────────────────────────────────────────────
// Reelst Firestore security rules
//
// Public-by-default for read (agent profiles, pins, sitemap)
// Strict ownership for writes — users can only mutate their own data
// Showing requests are write-anywhere (lead capture) but read-protected
// ─────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── USERS ──
    // Public read (agent profiles are discoverable)
    // Users can create their own doc on signup
    // Only the user can update their doc
    match /users/{uid} {
      allow read: if true;
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false; // soft-delete via account deactivation only
    }

    // ── USERNAMES (username → uid lookup table) ──
    // Public read so login/profile lookups work
    // Only the claiming user can create their own entry
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── PINS (listings + neighborhoods) ──
    // Public read — anyone can see active listings
    // Only the owning agent can write
    match /pins/{pinId} {
      allow read: if true;
      // New pins must default to enabled=false. Activation goes through
      // the setPinEnabled callable so the per-tier active-pin cap is
      // enforced server-side.
      allow create: if isSignedIn()
        && request.resource.data.agentId == request.auth.uid
        && request.resource.data.enabled == false;
      // Owners may freely update most fields and may DISABLE a pin
      // (enabled: false), but flipping enabled to true must go through
      // the setPinEnabled callable. archivePin sets enabled=false so it
      // continues to work.
      allow update: if isSignedIn()
        && resource.data.agentId == request.auth.uid
        && (
          request.resource.data.enabled == resource.data.enabled
          || request.resource.data.enabled == false
        );
      allow delete: if isSignedIn() && resource.data.agentId == request.auth.uid;
    }

    // ── FOLLOWS ──
    // Public read (follower lists, counts)
    // Only the follower can create/delete their own follow doc
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerUid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerUid == request.auth.uid;
      allow update: if false;
    }

    // ── SAVES (bookmarks) ──
    // Private to the user — only the saver can read/write their own saves
    match /saves/{saveId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ── SHOWING REQUESTS ──
    // ANYONE can create a request (lead capture form on listings)
    // Only the receiving agent can read/update/delete
    match /showing_requests/{reqId} {
      allow create: if true;
      allow read: if isSignedIn() && resource.data.agentId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.agentId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.agentId == request.auth.uid;
    }

    // ── SHARED MAPS (publicly shareable saved-pin collections) ──
    // Public read (that's the whole point — links are shareable)
    // Only the owner can create/update their share
    match /shared_maps/{shareId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── REPORTS (content moderation) ──
    // Any signed-in user can create a report
    // Only the reporter can read their own reports
    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterUid == request.auth.uid;
      allow read: if isSignedIn() && resource.data.reporterUid == request.auth.uid;
      allow update, delete: if false; // admin-only via Cloud Functions
    }

    // ── CONTENT LIBRARY (standalone media items) ──
    // Only the owning agent can CRUD their own content
    match /content/{contentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.agentId == request.auth.uid;
    }

    // ── DMCA TAKEDOWN REQUESTS ──
    // Anyone can submit a DMCA request (copyright holders may not have accounts)
    match /dmca_requests/{reqId} {
      allow create: if true;
      allow read, update, delete: if false; // admin-only
    }

    // ── LICENSE DISPUTES ──
    // Signed-in users can create disputes; only their own are readable
    match /disputes/{disputeId} {
      allow create: if isSignedIn() || true; // allow during signup (pre-auth)
      allow read: if isSignedIn() && (resource.data.claimantUid == request.auth.uid || resource.data.existingUid == request.auth.uid);
      allow update, delete: if false;
    }

    // ── NOTIFICATIONS ──
    // Agents can read their own notifications and mark as read
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.agentId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.agentId == request.auth.uid;
      allow create, delete: if false; // Cloud Functions only
    }

    // ── ANALYTICS EVENTS ──
    // Read by the agent for their own insights
    match /events/{eventId} {
      allow read: if isSignedIn() && resource.data.agentId == request.auth.uid;
      allow create, update, delete: if false; // Cloud Functions only
    }

    // ── FOLLOWER SNAPSHOTS ──
    match /follower_snapshots/{snapId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false; // Cloud Functions only
    }

    // ── MUX ASSETS ──
    match /muxAssets/{assetId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ── COMMENTS ──
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (
        resource.data.authorUid == request.auth.uid ||
        resource.data.pinAgentId == request.auth.uid
      );
      allow update: if false;
    }

    // ── RATE LIMITS ──
    // Server-only — only Cloud Functions (admin SDK) write/read these.
    // Backs the per-user rate limit on propertyLookup.
    match /rateLimits/{key} {
      allow read, write: if false;
    }

    // ── DIGEST SUBSCRIPTIONS (Save Maya — email-only) ──
    // Buyers create subscriptions anonymously (no auth required) — the
    // doc id is deterministic (`{agentId}_{emailHash}`) so duplicate
    // saves dedupe naturally. The owning agent can read their own
    // subscriber list. Updates restricted to status flips (active ↔
    // unsubscribed) — full doc shape is owned by the server when we
    // add the digest engine.
    match /digestSubscriptions/{subId} {
      allow read: if isSignedIn()
        && resource.data.agentId == request.auth.uid;
      allow create: if request.resource.data.status == 'active'
        && request.resource.data.agentId is string
        && request.resource.data.email is string;
      allow update: if isSignedIn()
        && resource.data.agentId == request.auth.uid
        && request.resource.data.agentId == resource.data.agentId
        && request.resource.data.email == resource.data.email;
      allow delete: if isSignedIn()
        && resource.data.agentId == request.auth.uid;
    }

    // ── WAVES (buyer questions on listings) ──
    // Subcollection of pins. Buyer creates go through the submitWave
    // callable Cloud Function (rate-limited, validated, admin-SDK
    // write) — direct client creates are denied. Owning agent can
    // read + update (mark read / change status).
    match /pins/{pinId}/waves/{waveId} {
      allow read: if isSignedIn()
        && get(/databases/$(database)/documents/pins/$(pinId)).data.agentId == request.auth.uid;
      allow update: if isSignedIn()
        && get(/databases/$(database)/documents/pins/$(pinId)).data.agentId == request.auth.uid;
      allow create, delete: if false;
    }

    // ── PIN PENDING CHANGES (subcollection of pins) ──
    // Written by the syncPropertyData scheduled function. The pin's
    // owning agent can read + delete (delete = approve/reject). No
    // direct client writes — the Cloud Function is the only producer.
    match /pins/{pinId}/pendingChanges/{changeId} {
      allow read: if isSignedIn()
        && get(/databases/$(database)/documents/pins/$(pinId)).data.agentId == request.auth.uid;
      allow delete: if isSignedIn()
        && get(/databases/$(database)/documents/pins/$(pinId)).data.agentId == request.auth.uid;
      allow create, update: if false;
    }

    // ── DEFAULT DENY ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
