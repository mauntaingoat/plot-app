rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — anyone can read public profiles, only owner can write
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Usernames — anyone can read (for availability check), only authenticated can create
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Pins — anyone can read enabled pins, only the agent who owns them can write
    match /pins/{pinId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.agentId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.agentId;
    }

    // Follows — anyone can read, authenticated users create/delete their own
    match /follows/{followId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Saves — owner can read/write their own saves
    match /saves/{saveId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
