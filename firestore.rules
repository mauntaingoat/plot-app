rules_version = '2';

// ─────────────────────────────────────────────────────────────────────
// Reelst Firestore security rules
//
// Public-by-default for read (agent profiles, pins, sitemap)
// Strict ownership for writes — users can only mutate their own data
// Showing requests are write-anywhere (lead capture) but read-protected
// ─────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── USERS ──
    // Public read (agent profiles are discoverable)
    // Users can create their own doc on signup
    // Only the user can update their doc
    match /users/{uid} {
      allow read: if true;
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false; // soft-delete via account deactivation only
    }

    // ── USERNAMES (username → uid lookup table) ──
    // Public read so login/profile lookups work
    // Only the claiming user can create their own entry
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── PINS (listings + neighborhoods) ──
    // Public read — anyone can see active listings
    // Only the owning agent can write
    match /pins/{pinId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.agentId == request.auth.uid;
    }

    // ── FOLLOWS ──
    // Public read (follower lists, counts)
    // Only the follower can create/delete their own follow doc
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.followerUid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.followerUid == request.auth.uid;
      allow update: if false;
    }

    // ── SAVES (bookmarks) ──
    // Private to the user — only the saver can read/write their own saves
    match /saves/{saveId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ── SHOWING REQUESTS ──
    // ANYONE can create a request (lead capture form on listings)
    // Only the receiving agent can read/update/delete
    match /showing_requests/{reqId} {
      allow create: if true;
      allow read: if isSignedIn() && resource.data.agentId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.agentId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.agentId == request.auth.uid;
    }

    // ── SHARED MAPS (publicly shareable saved-pin collections) ──
    // Public read (that's the whole point — links are shareable)
    // Only the owner can create/update their share
    match /shared_maps/{shareId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── REPORTS (content moderation) ──
    // Any signed-in user can create a report
    // Only the reporter can read their own reports
    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterUid == request.auth.uid;
      allow read: if isSignedIn() && resource.data.reporterUid == request.auth.uid;
      allow update, delete: if false; // admin-only via Cloud Functions
    }

    // ── CONTENT LIBRARY (standalone media items) ──
    // Only the owning agent can CRUD their own content
    match /content/{contentId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.agentId == request.auth.uid;
    }

    // ── DMCA TAKEDOWN REQUESTS ──
    // Anyone can submit a DMCA request (copyright holders may not have accounts)
    match /dmca_requests/{reqId} {
      allow create: if true;
      allow read, update, delete: if false; // admin-only
    }

    // ── LICENSE DISPUTES ──
    // Signed-in users can create disputes; only their own are readable
    match /disputes/{disputeId} {
      allow create: if isSignedIn() || true; // allow during signup (pre-auth)
      allow read: if isSignedIn() && (resource.data.claimantUid == request.auth.uid || resource.data.existingUid == request.auth.uid);
      allow update, delete: if false;
    }

    // ── NOTIFICATIONS ──
    // Agents can read their own notifications and mark as read
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.agentId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.agentId == request.auth.uid;
      allow create, delete: if false; // Cloud Functions only
    }

    // ── ANALYTICS EVENTS ──
    // Read by the agent for their own insights
    match /events/{eventId} {
      allow read: if isSignedIn() && resource.data.agentId == request.auth.uid;
      allow create, update, delete: if false; // Cloud Functions only
    }

    // ── FOLLOWER SNAPSHOTS ──
    match /follower_snapshots/{snapId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false; // Cloud Functions only
    }

    // ── MUX ASSETS ──
    match /muxAssets/{assetId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ── DEFAULT DENY ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
